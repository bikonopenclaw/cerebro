{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OperationRequest",
  "type": "object",
  "required": [
    "campaign_id",
    "asset_id",
    "operation",
    "tool",
    "parameters",
    "version"
  ],
  "properties": {
    "campaign_id": {
      "type": "string"
    },
    "asset_id": {
      "type": "string"
    },
    "operation": {
      "type": "string"
    },
    "tool": {
      "type": "string"
    },
    "parameters": {
      "type": "object"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "max_cost": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "request_hash": {
      "type": "string"
    }
  },
  "additionalProperties": false
}