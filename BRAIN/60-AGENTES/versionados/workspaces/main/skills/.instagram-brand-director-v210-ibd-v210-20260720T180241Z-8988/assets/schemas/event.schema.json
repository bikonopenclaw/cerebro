{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Event",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "stream_version",
    "prev_event_hash",
    "event_hash",
    "correlation_id",
    "campaign_id",
    "asset_id",
    "event_version",
    "timestamp_utc",
    "actor",
    "action",
    "result",
    "before_hash",
    "after_hash",
    "detail"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "stream_version": {
      "type": "integer",
      "minimum": 1
    },
    "prev_event_hash": {
      "type": "string",
      "pattern": "^$|^[a-f0-9]{64}$"
    },
    "event_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "correlation_id": {
      "type": "string"
    },
    "campaign_id": {
      "type": "string"
    },
    "asset_id": {
      "type": "string"
    },
    "event_version": {
      "type": "integer",
      "minimum": 1
    },
    "timestamp_utc": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "result": {
      "type": "string"
    },
    "before_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "after_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "detail": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
