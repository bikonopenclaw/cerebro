{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Approval",
  "type": "object",
  "required": [
    "approval_id",
    "status",
    "campaign_id",
    "asset_id",
    "asset_version",
    "action",
    "destination",
    "payload_hash",
    "approved_by_role",
    "approved_by_id",
    "approved_channel",
    "approved_chat_id",
    "approved_by_reference",
    "owner_message_hash",
    "approved_at",
    "expires_at",
    "revoked_at",
    "consumed_at",
    "provider_kind",
    "provider_id",
    "reserved_at",
    "execution_id",
    "execution_started_at",
    "completed_at",
    "outcome",
    "result_event_id"
  ],
  "properties": {
    "approval_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pending",
        "approved",
        "reserved",
        "executing",
        "succeeded",
        "failed",
        "indeterminate",
        "revoked",
        "consumed"
      ]
    },
    "campaign_id": {
      "type": "string"
    },
    "asset_id": {
      "type": "string"
    },
    "asset_version": {
      "type": "integer",
      "minimum": 1
    },
    "action": {
      "type": "string"
    },
    "destination": {
      "type": "string"
    },
    "payload_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "approved_by_role": {
      "const": "proprietário"
    },
    "approved_by_id": {
      "type": "string"
    },
    "approved_channel": {
      "type": "string"
    },
    "approved_chat_id": {
      "type": "string"
    },
    "approved_by_reference": {
      "type": "string"
    },
    "owner_message_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "approved_at": {
      "type": "string"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "revoked_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "consumed_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": "string"
    },
    "provider_kind": {
      "type": "string"
    },
    "provider_id": {
      "type": "string"
    },
    "reserved_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "execution_id": {
      "type": "string"
    },
    "execution_started_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "outcome": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "succeeded",
        "failed",
        "indeterminate",
        null
      ]
    },
    "result_event_id": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
