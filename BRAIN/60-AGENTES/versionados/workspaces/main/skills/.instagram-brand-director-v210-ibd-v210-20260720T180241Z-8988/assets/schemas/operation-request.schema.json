{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OperationRequest",
  "type": "object",
  "required": [
    "campaign_id",
    "asset_id",
    "asset_version",
    "operation",
    "destination",
    "tool",
    "parameters"
  ],
  "properties": {
    "campaign_id": {
      "type": "string"
    },
    "asset_id": {
      "type": "string"
    },
    "asset_version": {
      "type": "integer",
      "minimum": 1
    },
    "operation": {
      "type": "string"
    },
    "destination": {
      "type": "string"
    },
    "tool": {
      "type": "string"
    },
    "parameters": {
      "type": "object"
    },
    "max_cost": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "payload_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "provider_kind": {
      "enum": [
        "image",
        "video",
        "tts",
        "storage",
        "publication",
        "search"
      ]
    },
    "provider_id": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
