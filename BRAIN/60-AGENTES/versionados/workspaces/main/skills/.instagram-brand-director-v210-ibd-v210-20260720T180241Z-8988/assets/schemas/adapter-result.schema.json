{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AdapterResult",
  "type": "object",
  "required": [
    "operation",
    "request_hash",
    "status",
    "timestamp_utc",
    "provider_kind",
    "provider_id",
    "execution_id",
    "event_id"
  ],
  "properties": {
    "operation": {
      "type": "string"
    },
    "request_hash": {
      "type": "string"
    },
    "status": {
      "enum": [
        "blocked",
        "succeeded",
        "failed",
        "indeterminate"
      ]
    },
    "timestamp_utc": {
      "type": "string"
    },
    "provider_kind": {
      "type": "string"
    },
    "provider_id": {
      "type": "string"
    },
    "execution_id": {
      "type": "string"
    },
    "event_id": {
      "type": "string"
    },
    "remote_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "cost": {
      "type": [
        "number",
        "null"
      ]
    },
    "evidence": {
      "type": "object"
    },
    "error": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
